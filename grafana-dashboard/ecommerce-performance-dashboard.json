{
  "__inputs": [],
  "__requires": [],
  "dashboard": {
    "title": "AI Performance Testing - E-Commerce Platform",
    "description": "AI-powered performance monitoring dashboard generated by the AI Performance Testing Assistant",
    "tags": ["performance", "ai", "ecommerce"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "rate(http_requests_total[1m])",
            "legendFormat": "{{route}}",
            "refId": "A"
          }
        ],
        "description": "HTTP request rate by endpoint"
      },
      {
        "id": 2,
        "title": "Response Time (95th Percentile)",
        "type": "graph",
        "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
            "legendFormat": "{{route}}",
            "refId": "A"
          }
        ],
        "description": "95th percentile response time by endpoint"
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
        "targets": [
          {
            "expr": "rate(app_errors_total[5m])",
            "legendFormat": "{{type}} - {{route}}",
            "refId": "A"
          }
        ],
        "description": "Application error rate by type"
      },
      {
        "id": 4,
        "title": "Active Users",
        "type": "stat",
        "gridPos": {"x": 0, "y": 8, "w": 4, "h": 6},
        "targets": [
          {
            "expr": "app_active_users",
            "refId": "A"
          }
        ],
        "description": "Currently active user sessions"
      },
      {
        "id": 5,
        "title": "Total Orders",
        "type": "stat",
        "gridPos": {"x": 4, "y": 8, "w": 4, "h": 6},
        "targets": [
          {
            "expr": "app_orders_total",
            "refId": "A"
          }
        ],
        "description": "Total orders placed"
      },
      {
        "id": 6,
        "title": "Total Revenue",
        "type": "stat",
        "gridPos": {"x": 8, "y": 8, "w": 4, "h": 6},
        "targets": [
          {
            "expr": "app_revenue_total",
            "refId": "A"
          }
        ],
        "description": "Total revenue generated"
      },
      {
        "id": 7,
        "title": "In-Flight Requests",
        "type": "stat",
        "gridPos": {"x": 12, "y": 8, "w": 4, "h": 6},
        "targets": [
          {
            "expr": "http_requests_in_progress",
            "refId": "A"
          }
        ],
        "description": "Requests currently in progress"
      },
      {
        "id": 8,
        "title": "DB Query Duration (95th Pctl)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket[5m])) by (le, query_type))",
            "legendFormat": "{{query_type}}",
            "refId": "A"
          }
        ],
        "description": "Database query performance by type"
      },
      {
        "id": 9,
        "title": "Memory Usage",
        "type": "gauge",
        "gridPos": {"x": 12, "y": 14, "w": 6, "h": 8},
        "targets": [
          {
            "expr": "process_resident_memory_bytes / 1024 / 1024",
            "legendFormat": "Memory (MB)",
            "refId": "A"
          }
        ],
        "description": "Process memory usage in MB"
      },
      {
        "id": 10,
        "title": "CPU Usage",
        "type": "gauge",
        "gridPos": {"x": 18, "y": 14, "w": 6, "h": 8},
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[5m]) * 100",
            "legendFormat": "CPU %",
            "refId": "A"
          }
        ],
        "description": "Process CPU usage percentage"
      },
      {
        "id": 11,
        "title": "Business Transaction Latency (k6)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 22, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(business_transaction_duration_sum[1m]) / rate(business_transaction_duration_count[1m])",
            "legendFormat": "Avg Transaction Duration",
            "refId": "A"
          }
        ],
        "description": "Average business transaction duration from k6 tests"
      },
      {
        "id": 12,
        "title": "Checkout Success Rate (k6)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 22, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(checkout_success_total[1m]) / (rate(checkout_success_total[1m]) + rate(checkout_failure_total[1m]))",
            "legendFormat": "Success Rate",
            "refId": "A"
          }
        ],
        "description": "Checkout success rate from load tests"
      }
    ]
  }
}
